  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "The Life Cycle of the Common Octopus by Emma Knight - By the Lake Book Club",
    "startDate": "2026-10-06T19:00:00-04:00",
    "endDate": "2026-10-06T19:00:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Assembly Hall",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1 Colonel Samuel Smith Park Dr",
        "addressLocality": "Etobicoke",
        "addressRegion": "ON",
        "postalCode": "M8V 4B6",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.59766044,
        "longitude": -79.515824559
      }
    },
    "description": "The Life Cycle of the Common Octopus, by Emma Knight, shortlisted for the 2025 Scotiabank Giller Prize, is a spellbinding debut about friendship, motherhood, first love and the secrets that shape us. Set against the moody backdrop of Edinburgh, the novel follows Pen, a Canadian student unraveling a family mystery while navigating independence and desire. With wit and emotional depth, Knight explores womanhood and the choices that bind us.\n\nBy the Lake Book Club hosts six Tuesday-night events from February to December with top Canadian authors and Humber Polytechnics alumni. Each in-person event features readings, discussions, Q&A, book signings and ASL interpretation, while virtual sessions include live subtitles and audio access.",
    "url": "https://secure.toronto.ca/webapps/feps_edc-ticketing/#events/4c24b080-834a-499a-8d4f-4dd578c9d279",
