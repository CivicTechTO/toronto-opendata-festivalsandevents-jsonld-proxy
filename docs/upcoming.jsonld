    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Women and Flowers: Transplanted",
    "startDate": "2026-05-30T10:00:00-04:00",
    "endDate": "2026-06-18T10:00:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Cedar Ridge Creative Centre",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "225 Confederation Dr",
        "addressLocality": "Scarborough",
        "addressRegion": "ON",
        "postalCode": "M1G 1B2",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.75743,
        "longitude": -79.207132
      }
    },
    "description": "Gathering multiple histories, geographies and cultural lineages within a shared space, these five immigrant women artists reflect the World in a City – where distant homelands, memories and identities coexist and take root. Each artist has experienced displacement and, through their work, connect lived realities with the fragility and resilience of flowers. By situating women's stories alongside flowers as equally independent yet interwoven beings, this project foregrounds cycles of rupture and renewal, resilience and rebirth. Featuring works by Arshin Agashteh, Maryam (Sora) Kheiry, Ebru Winegrad, Golbahar Hassanabadi and Gizem Candan.",
    "url": "https://www.toronto.ca/explore-enjoy/history-art-culture/cultural-centres-galleries/cedar-ridge-creative-centre/",
    "image": "https://s3.ca-central-1.amazonaws.com/c3api-penguin-prod-toronto-storagestack-oc9o88-uploads/mKh3RlZsCws4tL79fFh28w",
    "organizer": {
      "@type": "Organization",
      "name": "",
      "email": "crcc@toronto.ca",
      "telephone": "4163964026"
    },
    "isAccessibleForFree": true,
    "keywords": [
      "Arts/Exhibits",
      "Cultural"
    ]
  },
