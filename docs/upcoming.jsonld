  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Hilary Hahn on Violin with Tom Poster on Piano",
    "startDate": "2026-05-21T19:00:00-04:00",
    "endDate": "2026-05-21T19:00:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Koerner Hall, Royal Conservatory of Music",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "273 Bloor St W",
        "addressLocality": "Toronto",
        "addressRegion": "ON",
        "postalCode": "M5S 1W2",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.667856304,
        "longitude": -79.396058814
      }
    },
    "description": "Three-time Grammy Award-winning violinist Hilary Hahn melds expressive musicality and technical expertise with a diverse repertoire guided by artistic curiosity. She is currently artist-in-residence at both the Chicago Symphony Orchestra and London's Wigmore Hall, and is co-founder and vice president of artistic partnerships of the AI-music initiative Deepmusic.AI. Hahn is a prolific and celebrated recording artist whose 21 feature albums on Decca, Deutsche Grammophon, and Sony have all opened in the top ten of the Billboard charts.\n\nEnjoy her program of Maurice Ravel: Violin Sonata No. 2 in G Major, M. 77, Bun-Ching Lam: Solitude d'automne, Lili Boulanger: Nocturne, Maurice Ravel: Pièce en forme de Habanera, M. 51, Claude Debussy: Sonata for Violin and Piano in G Minor, Scott Tixier: new duo work (North American premiere), and Gabriel Fauré: Violin Sonata No. 1 in A Major, op. 13.",
    "url": "https://www.rcmusic.com/Tickets/Seats/299201",
    "image": null,
    "organizer": {
      "@type": "Organization",
      "name": "Royal Conservatory of Music",
      "email": null,
      "telephone": null
    },
    "isAccessibleForFree": false,
    "keywords": [
      "Arts/Exhibits",
      "Live Performances",
      "Music"
    ],
    "offers": {
      "@type": "Offer",
      "price": "70.00",
      "priceCurrency": "CAD",
      "url": "https://www.rcmusic.com/Tickets/Seats/299201"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Penderecki Quartet 40th Anniversary Concert",
    "startDate": "2026-05-21T18:30:00-04:00",
    "endDate": "2026-05-21T18:30:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Jane Mallett Theatre, St. Lawrence Centre for the Arts",
      "address": {
        "@type": "PostalAddress",
