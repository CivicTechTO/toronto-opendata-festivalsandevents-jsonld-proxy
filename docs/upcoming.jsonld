  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Held by Anne Michaels - By the Lake Book Club",
    "startDate": "2026-12-08T19:00:00-05:00",
    "endDate": "2026-12-08T19:00:00-05:00",
    "location": {
      "@type": "Place",
      "name": "Assembly Hall",
      "address": {
