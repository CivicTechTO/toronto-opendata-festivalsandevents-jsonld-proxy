    "@context": "https://schema.org",
    "@type": "Event",
    "name": "10 Days in a Madhouse",
    "startDate": "2026-06-16T19:30:00-04:00",
    "endDate": "2026-06-21T13:30:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Bluma Appel Theatre",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "27 Front St E",
