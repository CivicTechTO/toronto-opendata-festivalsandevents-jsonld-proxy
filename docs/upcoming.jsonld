  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Dance: Paintings by Caroline Marshall",
    "startDate": "2026-05-21T11:00:00-04:00",
    "endDate": "2026-06-03T11:00:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Muse  Gallery",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1230 Yonge St",
        "addressLocality": "Toronto",
        "addressRegion": "ON",
        "postalCode": "M4T 1W3",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.682447,
        "longitude": -79.392049
      }
    },
    "description": "I slap and slide paint from the base of a canvas and move upward with my palette knife. \n\nUnrefined segments of various shades and colour rock and roll, lines intercept blocks and many go beyond the forms they touch. A rhythmic figure appears surrounded by a simple neutral background.  \n\nThe figure is a dancer. It's limbs flail, forms jump or twist and the body of my loosely composed figure vibrates with the music it hears. The subject moves alone, unaware that viewers are watching. \n\nMy abstract landscapes involve a dialogue or relationship between areas of intensity or excitement on the canvas and space. The many times I have driven past Outaouais fields and inland roads near Mont Jolie, Qc. have left their imprint. While still using geometric forms, the abstract landscapes are based on nature.",
    "url": "https://www.musegallery.ca/exhibitions",
    "image": "https://s3.ca-central-1.amazonaws.com/c3api-penguin-prod-toronto-storagestack-oc9o88-uploads/Va3Rl8q98LZia_B6S0CylA",
    "organizer": {
      "@type": "Organization",
      "name": "",
      "email": "contact@musegallery.ca",
      "telephone": "1-416-974-9986"
    },
    "isAccessibleForFree": true,
    "keywords": [
      "Arts/Exhibits",
      "Cultural"
    ]
  },
