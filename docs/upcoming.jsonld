  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Bees: A Story of Survival",
    "startDate": "2026-05-16T10:00:00-04:00",
    "endDate": "2026-09-09T10:00:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Royal Ontario Museum",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "100 Queen's Park",
        "addressLocality": "Toronto",
        "addressRegion": "ON",
        "postalCode": "M5S 2C6",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.667795387,
        "longitude": -79.394212289
      }
    },
    "description": "Bringing some buzz into your summer.\n\nJourney into the world of bees in a stunning new immersive experience that brings together the beauty of art with the power of science. Created by the National Museums Liverpool in partnership with award-winning artist and sculptor, Wolfgang Buttress, the exhibition highlights 120-million years of bee adaptation and survival, telling the epic tale of these incredible creatures and their relationship to us and the natural world.\n\nBased on science and full of imagination, the experiential exhibition presents a fusion of nature, art, music, and architecture that transports visitors into the world of bees - from the tiny, fascinating anatomy of a single bee and the magical wonder of honey bee colonies to the important roles bees play in our lives and the everyday threats they face.\n\nThrough immersive environments, art installations, soundscapes, and more, learn about the life of bees and the world they inhabit.",
    "url": "https://www.rom.on.ca/whats-on/exhibitions/bees-story-survival?utm_source=cityoftoronto&utm_medium=listing&utm_campaign=bees",
    "image": "https://s3.ca-central-1.amazonaws.com/c3api-penguin-prod-toronto-storagestack-oc9o88-uploads/Ror5HM-qhsFh4VYyqOZ1Qg",
    "organizer": {
      "@type": "Organization",
      "name": "",
      "email": "info@rom.on.ca",
      "telephone": "416-586-8000"
    },
    "isAccessibleForFree": false,
    "keywords": [
      "Arts/Exhibits",
      "Environmental",
      "Museum"
    ],
    "offers": {
      "@type": "Offer",
      "price": "29.00",
      "priceCurrency": "CAD",
      "url": "https://www.rom.on.ca/whats-on/exhibitions/bees-story-survival?utm_source=cityoftoronto&utm_medium=listing&utm_campaign=bees"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Yacht Rock Show Celebration",
    "startDate": "2026-05-16T19:30:00-04:00",
    "endDate": "2026-05-16T19:30:00-04:00",
    "location": {
      "@type": "Place",
      "name": "The El Mocambo",
      "address": {
        "@type": "PostalAddress",
