  {
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Los Callejeros Exhibition",
    "startDate": "2026-06-18T10:00:00-04:00",
    "endDate": "2026-07-23T10:00:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Assembly Hall Gallery",
      "address": {
        "@type": "PostalAddress",
