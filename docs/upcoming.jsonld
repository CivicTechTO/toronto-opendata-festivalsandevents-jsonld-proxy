    "@context": "https://schema.org",
    "@type": "Event",
    "name": "How to Survive a Bear Attack by Claire Cameron - By the Lake Book Club",
    "startDate": "2026-09-15T19:00:00-04:00",
    "endDate": "2026-09-15T19:00:00-04:00",
    "location": {
      "@type": "Place",
      "name": "Assembly Hall",
      "address": {
